# Open Response Center local development settings
DJANGO_SECRET_KEY=change-me
DJANGO_DEBUG=false
ORC_BIND_HOST=100.x.y.z
DJANGO_ALLOWED_HOSTS=100.x.y.z,host.tailnet-name.ts.net
DJANGO_CSRF_TRUSTED_ORIGINS=http://100.x.y.z:8000,https://host.tailnet-name.ts.net
DJANGO_SQLITE_PATH=/app/data/db.sqlite3
DJANGO_MEDIA_ROOT=/app/data/uploads
DJANGO_STATIC_ROOT=/app/staticfiles
DEFAULT_FROM_EMAIL=open-response-center@example.invalid
SMTP_HOST=
SMTP_PORT=587
SMTP_USE_TLS=true
SMTP_USER=
SMTP_PASSWORD=
OPENCLAW_WORKSPACE_ROOT=/workspace
GUNICORN_WORKERS=2
RSK_ENABLE_REMOTE_USER_AUTH=false
RSK_REMOTE_USER_HEADER=HTTP_X_REMOTE_USER
RSK_REMOTE_USER_EMAIL_HEADER=HTTP_X_REMOTE_EMAIL
RSK_REMOTE_USER_FIRST_NAME_HEADER=HTTP_X_REMOTE_FIRST_NAME
RSK_REMOTE_USER_LAST_NAME_HEADER=HTTP_X_REMOTE_LAST_NAME
RSK_REMOTE_USER_STAFF_HEADER=
